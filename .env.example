# Required
PRT_TRUETIME_API_KEY=your_key_here

# Optional
PRT_TRUETIME_BASE_URL=https://truetime.portauthority.org/bustime/api/v3
PRT_REQUEST_TIMEOUT_MS=15000
PRT_MAX_RETRIES=2
PRT_USER_AGENT=prt-mcp/0.1.0

# HTTP mode (optional)
HOST=127.0.0.1
PORT=3000

# Comma-separated allowlists for HTTP hardening
# Example: MCP_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
MCP_ALLOWED_HOSTS=
# Example: MCP_ALLOWED_ORIGINS=https://your-client.example.com
MCP_ALLOWED_ORIGINS=

# Optional bearer auth (set in production)
MCP_AUTH_TOKEN=

# Optional in-memory rate limiting for /mcp
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120
